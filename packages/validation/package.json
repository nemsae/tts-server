  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "zod": "^4.3.6"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nemsae/tts-server.git",
    "directory": "packages/validation"
  },
  "homepage": "https://github.com/nemsae/tts-server/tree/main/packages/validation",
  "bugs": {
    "url": "https://github.com/nemsae/tts-server/issues"
  },
  "keywords": [
    "tts",
    "validation",
    "zod",
    "schemas"
  ]
