# GCP Cloud Run Environment Variables
# These will be set via Secret Manager in production

# OpenAI API Key (stored in Secret Manager as 'openai-api-key')
OPENAI_API_KEY=sk-proj-your-openai-api-key

# Frontend URL for CORS (stored in Secret Manager as 'client-url')
CLIENT_URL=http://localhost:5173

# Port (automatically set by Cloud Run, default: 8080)
PORT=8080